# Excluir del contexto de build de Docker

# Dependencias (se reinstalan en el Stage 1)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build artifacts (se generan dentro del contenedor)
.next
out
build

# Control de versiones
.git
.gitignore

# Variables de entorno (se pasan en runtime, no en build)
.env
.env.local
.env.development
.env.test

# Sistema operativo
.DS_Store
Thumbs.db

# NOTA: tsconfig.json NO se excluye — es necesario para resolver alias @/* en el build
# NOTA: next.config.ts NO se excluye — es la configuración principal de Next.js
# NOTA: src/ NO se excluye — es el código fuente de la aplicación
